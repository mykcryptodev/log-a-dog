{
  "expo": {
    "name": "Log a Dog",
    "slug": "log-a-dog",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "logadog",
    "jsEngine": "hermes",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8EC"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.logadog.app",
      "newArchEnabled": false,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Log a Dog needs access to your photos to submit a hotdog.",
        "NSCameraUsageDescription": "Log a Dog needs your camera to snap a hotdog pic."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF8EC"
      },
      "package": "com.logadog.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ],
      "newArchEnabled": false,
      "minSdkVersion": 26
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Log a Dog needs your photos to submit a hotdog.",
          "cameraPermission": "Log a Dog needs your camera to snap a hotdog pic."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "extraMavenRepos": [
              "https://www.jitpack.io"
            ],
            "packagingOptions": {
              "pickFirst": [
                "**/libc++_shared.so",
                "**/libfbjni.so"
              ]
            }
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "9ff89265-30a6-4617-9392-c587cf7896bc"
      }
    },
    "owner": "mike12789"
  }
}
